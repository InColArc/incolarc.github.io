<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Das Fachwerkhaus — Collaboration Infrastructure Diagnostic</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=IBM+Plex+Sans:wght@400;500&family=IBM+Plex+Mono:wght@400&display=swap');
:root{--paper:#F5F0E8;--ink:#2C2A26;--ink-light:#6B6860;--ink-faint:#B5B0A5;--terracotta:#C4613A;--beam:#8B7355;--beam-dark:#5C4A33;--twig:#A89880;--culture:#C47A50;--habits:#A0694A;--roof-col:#6B5E50;--ff-display:'DM Serif Display',serif;--ff-body:'IBM Plex Sans',sans-serif;--ff-mono:'IBM Plex Mono',monospace}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--paper);color:var(--ink);font-family:var(--ff-body);font-size:16px;line-height:1.6}
.page{max-width:1100px;margin:0 auto;padding:2rem 1.5rem}
header{text-align:center;margin-bottom:2.5rem;padding-bottom:1.5rem;border-bottom:1px solid var(--ink-faint)}
header h1{font-family:var(--ff-display);font-size:2.2rem;font-weight:400}
header p{font-size:.95rem;color:var(--ink-light);margin-top:.4rem}
header .credit{font-family:var(--ff-mono);font-size:.7rem;color:var(--ink-faint);margin-top:.75rem}
header .credit a{color:var(--ink-light);text-decoration:none}
.layout{display:grid;grid-template-columns:1fr 380px;gap:2.5rem;align-items:start}
@media(max-width:860px){.layout{grid-template-columns:1fr}.house-panel{order:-1;position:static!important;max-width:400px;margin:0 auto}}
.questions-panel{min-width:0}
.section{margin-bottom:2rem}
.section-head{display:flex;align-items:center;gap:.6rem;margin-bottom:.75rem}
.section-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.section-dot.wall{background:var(--beam)}
.section-dot.brace{background:var(--culture)}
.section-dot.roof{background:var(--roof-col)}
.section-dot.gravity{background:var(--ink)}
.section-name{font-family:var(--ff-display);font-size:1.15rem;font-weight:400}
.question{margin-bottom:1.25rem;padding-left:22px}
.question-text{font-size:.9rem;margin-bottom:.4rem;line-height:1.5}
.options{list-style:none}
.options li{margin-bottom:.3rem}
.opt{display:block;width:100%;text-align:left;padding:.5rem .75rem;border:1px solid var(--ink-faint);border-radius:5px;background:transparent;cursor:pointer;font-family:var(--ff-body);font-size:.82rem;color:var(--ink-light);line-height:1.4;transition:all .15s}
.opt:hover{border-color:var(--ink-light);background:rgba(0,0,0,.02)}
.opt.s0{border-color:var(--ink-faint);color:var(--ink-faint);font-style:italic}
.opt.s1{border-color:var(--twig);background:rgba(168,152,128,.1);color:var(--beam-dark)}
.opt.s2{border-color:var(--beam-dark);background:rgba(92,74,51,.1);color:var(--beam-dark);font-weight:500}
.house-panel{position:sticky;top:1.5rem}
.house-frame{background:#fff;border:1px solid var(--ink-faint);border-radius:8px;padding:1.25rem}
.house-label{font-family:var(--ff-mono);font-size:.65rem;color:var(--ink-faint);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.5rem}
.house-svg{width:100%;height:auto;display:block}
.legend{display:flex;gap:1rem;margin-top:.75rem;flex-wrap:wrap}
.legend-item{display:flex;align-items:center;gap:.35rem;font-family:var(--ff-mono);font-size:.65rem;color:var(--ink-light)}
.legend-swatch{width:20px;height:8px;border-radius:2px}
.ptrack{height:2px;background:var(--ink-faint);border-radius:1px;margin-top:1rem;overflow:hidden}
.pbar{height:100%;width:0%;background:var(--ink);transition:width .4s}
.plabel{font-family:var(--ff-mono);font-size:.65rem;color:var(--ink-faint);margin-top:.3rem}
.gravity-area{text-align:center;margin:2rem 0;display:none}
.gravity-area.show{display:block}
.gravity-btn{font-family:var(--ff-display);font-size:1.3rem;padding:.8rem 2rem;border:2px solid var(--ink);background:transparent;color:var(--ink);cursor:pointer;border-radius:6px;transition:all .2s}
.gravity-btn:hover{background:var(--ink);color:var(--paper)}
.gravity-btn:disabled{opacity:.4;cursor:default}
.results{display:none;margin-top:1.5rem;padding:1.5rem;background:#fff;border:1px solid var(--ink-faint);border-radius:8px}
.results.show{display:block}
.results h2{font-family:var(--ff-display);font-size:1.4rem;font-weight:400;margin-bottom:.75rem}
.results p{font-size:.9rem;color:var(--ink-light);line-height:1.7;margin-bottom:.75rem}
.rblock{padding:1rem;border-radius:6px;margin-bottom:1rem}
.rblock h3{font-family:var(--ff-display);font-size:1.05rem;font-weight:400;margin-bottom:.4rem}
.rblock.cost{background:#F3E8E0;border-left:3px solid var(--terracotta)}
.rblock.cost h3{color:var(--terracotta)}
.rblock.grav{background:#E8E4DC;border-left:3px solid var(--ink-light)}
.rblock.grav h3{color:var(--ink)}
footer{margin-top:3rem;padding-top:1rem;border-top:1px solid var(--ink-faint);text-align:center;font-family:var(--ff-mono);font-size:.7rem;color:var(--ink-faint)}
footer a{color:var(--ink-light);text-decoration:none}
.element-group{transition:opacity .5s}
@keyframes tiltL{to{transform:rotate(-14deg)}}
@keyframes tiltR{to{transform:rotate(14deg)}}
@keyframes leanL{to{transform:rotate(-5deg)}}
@keyframes leanR{to{transform:rotate(5deg)}}
@keyframes rsink{to{transform:translateY(30px)}}
@keyframes buckle{0%,100%{transform:translateY(0) scaleY(1)}50%{transform:translateY(2px) scaleY(.96)}}
.grav-on .do-tiltL{animation:tiltL 2s ease-in forwards}
.grav-on .do-tiltR{animation:tiltR 2s ease-in forwards}
.grav-on .do-leanL{animation:leanL 1.5s ease-in forwards}
.grav-on .do-leanR{animation:leanR 1.5s ease-in forwards}
.grav-on .do-rsink{animation:rsink 2.5s ease-in .3s forwards}
.grav-on .do-buckle{animation:buckle 1.2s ease-in-out infinite}
</style>
</head>
